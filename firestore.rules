rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function userProfilePath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return isAuth() && exists(userProfilePath());
    }

    function getUserRole() {
      return hasUserProfile() ? get(userProfilePath()).data.role : null;
    }

    function isRole(role) {
      return getUserRole() == role;
    }

    function isStaff() {
      return getUserRole() in ['cook', 'cashier', 'manager', 'admin'];
    }

    function isStaffBalanceDebit() {
      return isStaff()
        && request.resource.data.balance is number
        && resource.data.balance is number
        && request.resource.data.balance < resource.data.balance
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']);
    }

    function isStaffValidatorWalletUpdate() {
      return isStaff()
        && request.resource.data.wallets is map
        && resource.data.wallets is map
        && request.resource.data.balance is number
        && resource.data.balance is number
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['wallets', 'balance']);
    }

    // ── users ────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read their own doc.
      // Staff/admin can read all.
      allow read: if isOwner(userId) || isStaff();

      // User can create/update their own doc (registration).
      // Admin can update anyone.
      allow create: if isAuth();
      allow update: if isOwner(userId) || isRole('admin') || isRole('manager') || isStaffBalanceDebit() || isStaffValidatorWalletUpdate();
      allow delete: if isRole('admin');

      match /wallet_history/{entryId} {
        allow read: if isOwner(userId) || isStaff();
        allow create: if isRole('admin') || isRole('manager') || isStaff();
        allow update, delete: if isRole('admin');
      }
    }

    // ── user_groups (CRM counterparty groups) ───────────────
    match /user_groups/{groupId} {
      allow read: if isStaff();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── loyalty_categories (CRM loyalty tiers) ─────────────
    match /loyalty_categories/{categoryId} {
      allow read: if isStaff();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── work_shifts (employee work shift reference) ────────
    match /work_shifts/{shiftId} {
      allow read: if isStaff();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── wallets (CRM wallet catalog) ───────────────────────
    match /wallets/{walletId} {
      allow read: if isStaff();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── payment_methods (payment types catalog) ───────────
    match /payment_methods/{methodId} {
      allow read: if isStaff();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── items (menu) ─────────────────────────────────────────
    match /items/{itemId} {
      allow read: if isAuth();
      allow create, delete: if isRole('admin') || isRole('manager');
      // Staff manage menu; any auth user may patch imageUrl or nutrition (dev seed helpers).
      allow update: if isRole('admin') || isRole('manager') || (
        isAuth() && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['imageUrl'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nutrition'])
        )
      );
    }

    // ── settings (menu categories, allergens) ───────────────
    match /settings/{docId} {
      allow read: if isAuth();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── availability_rules (centralized schedules) ──────────
    match /availability_rules/{ruleId} {
      allow read: if isAuth();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── promo_rules (marketing & loyalty) ─────────────────
    match /promo_rules/{promoId} {
      allow read: if isAuth();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── marketing_banners (stories & hero promos) ─────────
    match /marketing_banners/{bannerId} {
      allow read: if isAuth();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── validation_rules (cafeteria validator deduction rules) ─
    match /validation_rules/{ruleId} {
      allow read: if isStaff();
      allow write: if isRole('admin') || isRole('manager');
    }

    // ── validation_logs (card tap audit trail) ────────────
    match /validation_logs/{logId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isRole('admin') || isRole('manager') || isStaff();
    }

    function isOrderOwner() {
      return isAuth() && resource.data.userId == request.auth.uid;
    }

    function isUnpaidPendingOrder() {
      return resource.data.paymentStatus == 'unpaid'
        && resource.data.status == 'pending';
    }

    function isClientOrderCancel() {
      return isOrderOwner()
        && isUnpaidPendingOrder()
        && request.resource.data.status == 'cancelled'
        && request.resource.data.paymentStatus == 'unpaid'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    function isClientOrderItemsUpdate() {
      return isOrderOwner()
        && isUnpaidPendingOrder()
        && request.resource.data.status == resource.data.status
        && request.resource.data.paymentStatus == resource.data.paymentStatus
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['items']);
    }

    function isClientOrderPayment() {
      return isOrderOwner()
        && isUnpaidPendingOrder()
        && request.resource.data.paymentStatus == 'paid'
        && request.resource.data.status == 'cooking'
        && request.resource.data.checkId is string
        && request.resource.data.checkId.size() > 0
        && request.resource.data.items == resource.data.items
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkId', 'paymentStatus', 'status', 'paidAt']);
    }

    function isKioskGuestOrderPayment() {
      return isAuth()
        && resource.data.userId == 'kiosk-guest'
        && isUnpaidPendingOrder()
        && request.resource.data.paymentStatus == 'paid'
        && request.resource.data.status == 'cooking'
        && request.resource.data.checkId is string
        && request.resource.data.checkId.size() > 0
        && request.resource.data.items == resource.data.items
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkId', 'paymentStatus', 'status', 'paidAt']);
    }

    // Paid orders on the public queue board (cooking / ready only).
    function isPublicQueueOrder() {
      return resource.data.paymentStatus == 'paid'
        && resource.data.status in ['cooking', 'ready'];
    }

    // ── orders ───────────────────────────────────────────────
    match /orders/{orderId} {
      // Client reads own orders; staff reads all; queue screen reads active kitchen queue.
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isStaff() || isPublicQueueOrder()
      );
      // Client creates orders; staff updates status.
      allow create: if isAuth();
      allow update: if isStaff() || isClientOrderCancel() || isClientOrderItemsUpdate() || isClientOrderPayment() || isKioskGuestOrderPayment();
      allow delete: if isRole('admin');
    }

    // ── checks ───────────────────────────────────────────────
    match /checks/{checkId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isStaff()
      );
      // Created only server-side via transaction — allow from client for demo
      allow create: if isAuth();
      allow update, delete: if isRole('admin');
    }

    // ── transactions ─────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isStaff();
      allow create: if isAuth();
      allow update, delete: if isRole('admin');
    }

    function isStaffOrderNotification() {
      return isStaff()
        && request.resource.data.type == 'order'
        && request.resource.data.keys().hasAll(['userId', 'type', 'title', 'body', 'read', 'createdAt']);
    }

    // ── notifications ────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && (
        request.resource.data.userId == request.auth.uid
        || isStaffOrderNotification()
      );
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isRole('admin');
    }
  }
}
